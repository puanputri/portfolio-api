# ============================================================
# portfolio-api environment variables — copy to .env and fill
# ============================================================

# --------------- PostgreSQL ---------------
# JDBC connection URL for the primary datasource
DB_URL=jdbc:postgresql://localhost:5432/portfolio

# Database username
DB_USERNAME=portfolio_user

# Database password
DB_PASSWORD=changeme

# --------------- Mailer (SMTP) ---------------
# SMTP server hostname (e.g. smtp.gmail.com, smtp.sendgrid.net)
MAILER_HOST=smtp.gmail.com

# SMTP server port (587 for STARTTLS, 465 for SSL)
MAILER_PORT=587

# SMTP username (usually your email address)
MAILER_USERNAME=puanputrisaqinahf@gmail.com

# SMTP password or app-specific password
MAILER_PASSWORD=changeme

# Whether SMTP connection uses SSL (true/false)
MAILER_SSL=false

# Whether SMTP connection uses STARTTLS (true/false)
MAILER_STARTTLS=true

# The "From" address for outgoing notification emails
MAILER_FROM=no-reply@puanputri.dev

# Recipient email address for contact form notifications
CONTACT_NOTIFICATION_EMAIL=puanputrisaqinahf@gmail.com

# --------------- Application ---------------
# Log level: TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated for production)
# Example: https://puanputri.dev,https://www.puanputri.dev
CORS_ORIGINS=http://localhost:3000,https://puanputri.dev

# --------------- Kubernetes / Runtime ---------------
# Application HTTP port
HTTP_PORT=8080
